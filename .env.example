# Database (Required)
DATABASE_URL="postgresql://user:password@localhost:5432/vianu_db"

# Frontend API URL
# Leave empty for localhost (Vite proxy handles it automatically)
# Set to backend Railway URL only when frontend & backend are separate services:
# VITE_API_URL=https://your-backend.up.railway.app
VITE_API_URL=

# Authentication (Required in production)
# Generate with: openssl rand -base64 32
JWT_SECRET="your-super-secret-jwt-key-change-in-production"

# CORS - Comma-separated list of allowed origins (Required in production)
# Example: https://yourapp.com,https://www.yourapp.com
ALLOWED_ORIGINS="http://localhost:3000,http://localhost:5173"

# Environment (development | production)
NODE_ENV="development"
